<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.littlebit.Launcher</id>

  <name>LB Launcher</name>
  <name xml:lang="uk">LB Лаунчер</name>

  <summary>Installer for Ukrainian game localizations</summary>
  <summary xml:lang="uk">Встановлювач українізаторів відеоігор</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      LB Launcher is a desktop application for installing Ukrainian translations
      of video games. It automatically detects installed games and allows you to
      easily install, update, and manage Ukrainian localizations.
    </p>
    <p xml:lang="uk">
      LB Лаунчер - це настільний застосунок для встановлення українських
      перекладів відеоігор. Він автоматично виявляє встановлені ігри та дозволяє
      легко встановлювати, оновлювати та керувати українізаторами.
    </p>
    <p>Supported platforms:</p>
    <p xml:lang="uk">Підтримувані платформи:</p>
    <ul>
      <li>Steam (including Flatpak)</li>
      <li xml:lang="uk">Steam (включно з Flatpak)</li>
      <li>GOG Galaxy</li>
      <li>Epic Games Store</li>
      <li>Rockstar Games Launcher</li>
    </ul>
  </description>

  <launchable type="desktop-id">org.littlebit.Launcher.desktop</launchable>

  <url type="homepage">https://littlebit.org.ua</url>
  <url type="bugtracker">https://github.com/Vadko/littlebit-launcher/issues</url>
  <url type="donation">https://send.monobank.ua/jar/7BPAEkUJJZ</url>

  <developer id="org.littlebit">
    <name>LB UA Team</name>
    <name xml:lang="uk">Команда LB UA</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#3b82f6</color>
    <color type="primary" scheme_preference="dark">#1e40af</color>
  </branding>

  <content_rating type="oars-1.1" />

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>gamepad</control>
  </supports>

  <requires>
    <display_length compare="ge">768</display_length>
    <internet>always</internet>
  </requires>

  <categories>
    <category>Game</category>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>games</keyword>
    <keyword>localization</keyword>
    <keyword>translation</keyword>
    <keyword>ukrainian</keyword>
    <keyword>steam</keyword>
    <keyword>gog</keyword>
    <keyword>epic</keyword>
    <keyword xml:lang="uk">ігри</keyword>
    <keyword xml:lang="uk">локалізація</keyword>
    <keyword xml:lang="uk">переклад</keyword>
    <keyword xml:lang="uk">українізація</keyword>
  </keywords>

  <releases>
    <release version="1.19.9" date="2025-01-01">
      <description>
        <p>Latest release with improved game detection and UI enhancements.</p>
        <p xml:lang="uk">Останній реліз з покращеним виявленням ігор та вдосконаленим інтерфейсом.</p>
      </description>
    </release>
  </releases>

  <screenshots>
    <screenshot type="default">
      <caption>Main window with game list</caption>
      <caption xml:lang="uk">Головне вікно зі списком ігор</caption>
      <image>https://raw.githubusercontent.com/Vadko/littlebit-launcher/master/screenshots/main.png</image>
    </screenshot>
  </screenshots>
</component>
